DOCUMENT_INDEX_CACHE_ENABLED=true
DOCUMENT_INDEX_CACHE_DB_PATH=files_materials/_document_index_cache/index.sqlite3
DOCUMENT_INDEX_CACHE_LOCK_TIMEOUT_SECONDS=900
DOCUMENT_INDEX_CACHE_STALE_LOCK_SECONDS=21600
DOCUMENT_INDEX_CACHE_BUSY_TIMEOUT_MS=30000

LECTURE_TARGET_WORDS=5000
LECTURE_WORDS_PER_SECTION=850
LECTURE_MIN_SECTIONS=3
LECTURE_MAX_SECTIONS=9
LECTURE_CHUNK_TOKENS=700
LECTURE_BASE_PLAN_CONTEXT_CHUNKS=16
LECTURE_BASE_SECTION_CONTEXT_CHUNKS=10
LECTURE_MAX_PLAN_CONTEXT_CHUNKS=64
LECTURE_MAX_SECTION_CONTEXT_CHUNKS=32
LECTURE_RETRIEVAL_POOL_K=40
LECTURE_MAX_RETRIEVAL_POOL_K=180
LECTURE_PLAN_CONTEXT_TOKEN_BUDGET=24000
LECTURE_SECTION_CONTEXT_TOKEN_BUDGET=16000
LECTURE_DOCUMENT_PROFILES_ENABLED=true
LECTURE_DOC_PROFILE_CHUNKS=8
LECTURE_DOC_PROFILE_MAX_CHUNKS=16
LECTURE_DOC_PROFILE_MAX_TOKENS=700
LECTURE_FINAL_EDIT_ENABLED=true
LECTURE_FINAL_EDIT_INPUT_TOKEN_BUDGET=50000

PDF_FONT_REGULAR=

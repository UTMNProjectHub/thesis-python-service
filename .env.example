PROXYAPI_KEY=
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1
PROXYAPI_MODEL=gpt-4.1-mini
PROXYAPI_EMBEDDING_MODEL=text-embedding-3-small

DATABASE_URL=
REDIS_URL=
AMQP_URL=amqp://guest:guest@localhost:5672/
AMQP_HEARTBEAT=600

MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=materials
MINIO_SECURE=false
MINIO_REGION=us-east-1

QUIZ_SOURCE_MAX_CHARS=120000
QUIZ_SOURCE_MAX_CHARS_PER_FILE=30000
QUIZ_GENERATION_USE_SOURCE_DOCUMENTS=false
FAQ_GENERATION_USE_SOURCE_DOCUMENTS=false

S3_DOWNLOAD_CACHE_ENABLED=true
S3_DOWNLOAD_CACHE_DIR=files_materials/_s3_cache
